    <material name="cup_handle" rgba="0.1 0.6 0.9 1" specular="0.5" shininess="0.3"/>
    
    <!-- Robot base material -->
    <material name="robot_base" rgba="0.3 0.3 0.3 1" specular="0.3" shininess="0.2"/>
    
    <!-- Target zone -->
