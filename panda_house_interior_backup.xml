<mujoco model="panda house interior scene">
  <compiler angle="radian" meshdir="assets" autolimits="true"/>

  <statistic center="0.5 0 0.6" extent="2.5"/>

  <option timestep="0.002" iterations="200" ls_iterations="50" noslip_iterations="20" tolerance="1e-8" integrator="implicitfast">
    <flag eulerdamp="disable"/>
  </option>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.4 0.4 0.4" specular="0.2 0.2 0.2"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
    <scale contactwidth="0.075" contactheight="0.025" forcewidth="0.05"/>
  </visual>

  <default>
    <default class="panda">
      <material specular="0.5" shininess="0.25"/>
      <joint armature="0.1" damping="1" axis="0 0 1" range="-2.8973 2.8973"/>
      <general dyntype="none" biastype="affine" ctrlrange="-2.8973 2.8973" forcerange="-87 87"/>
      <position forcerange="-100 100"/>
      <default class="finger">
        <joint axis="0 1 0" type="slide" range="0 0.04"/>
      </default>

      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom group="3" type="mesh" contype="1" conaffinity="1" friction="1.5 0.05 0.001"/>
        <default class="primitive_collision">
          <geom group="3" type="box" contype="1" conaffinity="3"
           condim="3" solimp="0.999 0.999 0.0001" solref="0.0001 1" friction="3.0 0.005 0.0001"/>
          <default class="fingertip_pad_collision_1">
            <geom type="box" size="0.011 0.0075 0.0125" pos="0 0.0185 0.0125"/>
          </default>
          <default class="fingertip_pad_collision_2">
            <geom type="box" size="0.011 0.0044 0.0019" pos="0 0.0068 0.0022"/>
          </default>
          <default class="fingertip_pad_collision_3">
            <geom type="box" size="0.00875 0.0035 0.01175" pos="0 0.0159 0.02835" quat="1 0.25 0 0"/>
          </default>
          <default class="fingertip_pad_collision_4">
            <geom type="box" size="0.00875 0.0076 0.015" pos="0 0.00758 0.052" conaffinity="3"/>
          </default>
        </default>
      </default>
    </default>
  </default>

  <asset>
    <!-- Skybox -->
    <texture type="skybox" builtin="gradient" rgb1="0.4 0.6 0.8" rgb2="0.1 0.1 0.2" width="512" height="3072"/>
    
    <!-- Floor textures -->
    <texture type="2d" name="wood_floor" builtin="checker" mark="edge" 
      rgb1="0.6 0.4 0.2" rgb2="0.5 0.35 0.18"
      markrgb="0.7 0.5 0.3" width="300" height="300"/>
    <material name="wood_floor" texture="wood_floor" texuniform="true" texrepeat="8 8" reflectance="0.15"/>
    
    <!-- Wall textures -->
    <texture type="2d" name="wall_texture" builtin="flat" 
      rgb1="0.9 0.88 0.85" width="100" height="100"/>
    <material name="wall_mat" texture="wall_texture" rgba="0.92 0.90 0.87 1" reflectance="0.05"/>
    
    <!-- Coffee table material (wood) -->
    <texture type="2d" name="dark_wood" builtin="checker" 
      rgb1="0.3 0.2 0.1" rgb2="0.25 0.15 0.08" width="100" height="100"/>
    <material name="table_wood" texture="dark_wood" texrepeat="2 2" rgba="0.4 0.25 0.15 1" specular="0.3" shininess="0.2"/>
    
    <!-- Sofa materials -->
    <material name="sofa_fabric" rgba="0.2 0.3 0.5 1" specular="0.1" shininess="0.1"/>
    <material name="sofa_cushion" rgba="0.25 0.35 0.55 1" specular="0.1" shininess="0.1"/>
    
    <!-- Decorative items -->
    <material name="plant_pot" rgba="0.6 0.3 0.2 1" specular="0.4" shininess="0.3"/>
    <material name="plant_green" rgba="0.2 0.6 0.3 1" specular="0.2" shininess="0.1"/>
    <material name="book_cover" rgba="0.7 0.2 0.2 1"/>
    
